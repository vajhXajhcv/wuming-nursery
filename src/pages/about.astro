---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.about-hero {
				text-align: center;
				padding: 2em 0;
			}
			.about-hero img {
				width: 120px;
				height: 120px;
				border-radius: 50%;
				box-shadow: var(--box-shadow);
				border: 3px solid rgba(var(--gray-light), 1);
				margin-bottom: 1em;
				transition: transform 0.3s ease;
			}
			.about-hero img:hover {
				transform: scale(1.05);
			}
			.about-hero h1 {
				font-size: 2em;
				margin: 0 0 0.3em;
			}
			.about-hero p {
				color: rgb(var(--gray));
				margin: 0;
			}
			.section {
				margin: 2.5em 0;
			}
			.section h2 {
				font-size: 1.4em;
				margin-bottom: 0.8em;
				padding-bottom: 0.3em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.section p {
				color: rgb(var(--gray-dark));
				line-height: 1.8;
			}
			.timeline {
				position: relative;
				padding-left: 1.5em;
			}
			.timeline::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.5em;
				bottom: 0.5em;
				width: 3px;
				background: rgb(var(--gray-light));
				border-radius: 3px;
			}
			.timeline-item {
				position: relative;
				margin-bottom: 1.5em;
			}
			.timeline-item::before {
				content: '';
				position: absolute;
				left: -1.65em;
				top: 0.4em;
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: var(--accent);
			}
			.timeline-item .date {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 0.2em;
			}
			.timeline-item .content {
				color: rgb(var(--gray-dark));
			}
			.links {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
				margin-top: 1em;
			}
			.links a {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.5em 1em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				text-decoration: none;
				font-size: 0.9em;
				transition: all 0.2s ease;
			}
			.links a:hover {
				background: var(--accent);
				color: white;
				transform: translateY(-2px);
			}
			@media (max-width: 720px) {
				.about-hero h1 { font-size: 1.6em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero">
				<img src="/avatar.png" alt="头像" />
				<h1>关于我</h1>
				<p>「花园主」— 正在创作 GitHub 仓库新项目与 wumingmp.me 个人网站</p>
			</section>

			<section class="section">
				<h2>🌱 这里是「无名苗圃」</h2>
				<p>
					无名苗圃不只是博客，它是一个正在生长的<strong>一人公司实验场</strong>。
				</p>
				<p>
					我会在这里记录独立开发的踩坑过程、AI 工具的实测体验、从 0 到 1 做产品的思考，以及那些还没名字但正在发芽的想法。
				</p>
				<p>
					如果你也在探索「用代码和内容养活自己」这条路，欢迎订阅、交流、或者直接用右侧的方式找到我。
				</p>
			</section>

			<section class="section">
				<h2>💡 我能提供什么</h2>
				<div class="timeline">
					<div class="timeline-item">
						<div class="date">🛠 网站开发</div>
						<div class="content">个人品牌站、Landing Page、博客搭建。Astro + Cloudflare，快、省、SEO 友好。</div>
					</div>
					<div class="timeline-item">
						<div class="date">🤖 AI 自动化</div>
						<div class="content">内容生成管线、智能客服、AI 工作流搭建。让重复劳动消失，把时间留给创造。</div>
					</div>
					<div class="timeline-item">
						<div class="date">📄 文档工具</div>
						<div class="content">Markdown 转学术 Word、批量排版、模板定制。基于自研 docx-formatter-cn 工具链。</div>
					</div>
					<div class="timeline-item">
						<div class="date">✍️ 内容策略</div>
						<div class="content">SEO 技术文章、Newsletter、产品文档。用内容换长期流量，用流量换可持续收入。</div>
					</div>
				</div>
			</section>

			<section class="section">
				<h2>📌 时间线</h2>
				<div class="timeline">
					<div class="timeline-item">
						<div class="date">2026 年 6 月</div>
						<div class="content">网站定位升级：从个人博客转向一人公司与创作者品牌</div>
					</div>
					<div class="timeline-item">
						<div class="date">2026 年 6 月</div>
						<div class="content">发布《一人公司完全指南》系列文章，探索独立开发路径</div>
					</div>
					<div class="timeline-item">
						<div class="date">2026 年 5 月</div>
						<div class="content">搭建「无名苗圃」个人网站，基于 Astro + Cloudflare Pages</div>
					</div>
					<div class="timeline-item">
						<div class="date">2026 年 5 月</div>
						<div class="content">开发 docx-formatter-cn — 中文 Word 文档智能排版工具</div>
					</div>
				</div>
			</section>

			<section class="section">
				<h2>🔗 找到我</h2>
				<div class="links">
					<a href="https://github.com/vajhxajhcv" target="_blank" rel="noopener">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						GitHub
					</a>
					<a href="https://www.ifdian.net/a/jk342joy" target="_blank" rel="noopener">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
						爱发电
					</a>
					<a href="/rss.xml">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.739-23.98-24-24.026v4.838z"/></svg>
						RSS
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
