---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Hero */
			.hero {
				text-align: center;
				padding: 4em 1em 3em;
				position: relative;
				overflow: hidden;
			}
			#particle-canvas {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				pointer-events: none;
				z-index: 0;
			}
			.hero > * {
				position: relative;
				z-index: 1;
			}
			.hero .avatar {
				width: 100px;
				height: 100px;
				border-radius: 50%;
				margin-bottom: 1em;
				box-shadow: var(--box-shadow);
				border: 3px solid rgba(var(--gray-light), 1);
				transition: transform 0.3s ease;
			}
			.hero .avatar:hover {
				transform: scale(1.05) rotate(3deg);
			}
			.hero h1 {
				font-size: 3em;
				margin: 0 0 0.3em;
				background: linear-gradient(90deg, var(--accent), #8b5cf6);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero .subtitle {
				font-size: 1.3em;
				color: rgb(var(--gray));
				min-height: 1.6em;
			}
			.hero .desc {
				color: rgb(var(--gray-dark));
				margin-top: 1em;
				font-size: 1.05em;
			}
			.hero .social {
				margin-top: 1.5em;
				display: flex;
				gap: 1em;
				justify-content: center;
				flex-wrap: wrap;
			}
			.hero .social a {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.5em 1em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				text-decoration: none;
				font-size: 0.9em;
				transition: all 0.2s ease;
			}
			.hero .social a:hover {
				background: var(--accent);
				color: white;
				transform: translateY(-2px);
			}

			/* Sections */
			.section-title {
				font-size: 1.6em;
				margin: 2em 0 1em;
				padding-bottom: 0.3em;
				border-bottom: 2px solid rgb(var(--gray-light));
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.section-title a {
				font-size: 0.65em;
				color: var(--accent);
				text-decoration: none;
			}
			.section-title a:hover {
				text-decoration: underline;
			}

			/* Post cards */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 1.2em;
			}
			.post-card {
				background: white;
				border-radius: 12px;
				padding: 1.2em;
				box-shadow: 0 2px 8px rgba(var(--gray), 10%);
				transition: transform 0.2s ease, box-shadow 0.2s ease;
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.post-card h3 {
				margin: 0 0 0.4em;
				font-size: 1.1em;
				color: rgb(var(--black));
			}
			.post-card p {
				margin: 0;
				font-size: 0.9em;
				color: rgb(var(--gray));
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-card .date {
				margin-top: 0.6em;
				font-size: 0.8em;
				color: rgb(var(--gray));
			}

			/* Project card */
			.project-card {
				background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
				border-radius: 16px;
				padding: 1.5em;
				display: flex;
				gap: 1.5em;
				align-items: flex-start;
				border: 1px solid rgba(var(--gray-light), 1);
				transition: transform 0.2s ease, box-shadow 0.2s ease;
				text-decoration: none;
				color: inherit;
			}
			.project-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.project-icon {
				width: 48px;
				height: 48px;
				background: var(--accent);
				border-radius: 12px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-size: 1.5em;
				flex-shrink: 0;
			}
			.project-info h3 {
				margin: 0 0 0.3em;
				font-size: 1.2em;
			}
			.project-info p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.project-info .tags {
				margin-top: 0.6em;
				display: flex;
				gap: 0.4em;
				flex-wrap: wrap;
			}
			.project-info .tags span {
				font-size: 0.75em;
				padding: 0.2em 0.6em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}

			@media (max-width: 720px) {
				.hero h1 { font-size: 2.2em; }
				.project-card { flex-direction: column; gap: 1em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<canvas id="particle-canvas"></canvas>
				<img src="/avatar.png" alt="头像" class="avatar" />
				<h1>无名苗圃</h1>
				<p class="subtitle" id="typewriter"></p>
				<p class="desc">一个存放记忆与故事的地方。<br />游戏攻略、生活碎片、还有一些没名字的故事。</p>
				<div class="social">
					<a href="https://github.com/vajhxajhcv" target="_blank" rel="noopener">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						GitHub
					</a>
					<a href="https://afdian.com/a/%E8%8A%B1%E5%9B%AD%E4%B8%BB" target="_blank" rel="noopener">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
						爱发电
					</a>
					<a href="/rss.xml">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.739-23.98-24-24.026v4.838z"/></svg>
						RSS
					</a>
				</div>
			</section>

			<!-- Latest Posts -->
			{posts.length > 0 && (
				<section>
					<h2 class="section-title">
						最新文章
						<a href="/blog">查看全部 →</a>
					</h2>
					<div class="post-grid">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<div class="date">
									<FormattedDate date={post.data.pubDate} />
								</div>
							</a>
						))}
					</div>
				</section>
			)}

			<!-- Projects -->
			<section>
				<h2 class="section-title">
					项目
					<a href="/projects/docx-formatter-cn">查看详情 →</a>
				</h2>
				<a href="/projects/docx-formatter-cn" class="project-card">
					<div class="project-icon">📄</div>
					<div class="project-info">
						<h3>docx-formatter-cn</h3>
						<p>中文 Word 文档智能排版工具 — Markdown 一键转为符合学术规范的 docx</p>
						<div class="tags">
							<span>Python</span>
							<span>LaTeX</span>
							<span>Word</span>
						</div>
					</div>
				</a>
			</section>

			<!-- Site stats -->
			<section class="site-stats" style="text-align: center; margin-top: 3em; padding-top: 2em; border-top: 1px solid rgb(var(--gray-light)); color: rgb(var(--gray)); font-size: 0.9em;">
				<p>🌱 本站已运行 <span id="site-days">0</span> 天</p>
				<p style="margin-top: 0.5em;">
					<img src="https://count.getloli.com/get/@wumingmp.me?theme=rule34" alt="visitor count" style="height: 24px; vertical-align: middle;" />
				</p>
			</section>
		</main>
		<Footer />

		<!-- Typewriter effect -->
		<script>
			const phrases = [
				"慢慢来，不急。",
				"这里会生长出各种东西。",
				"游戏攻略、生活碎片、没名字的故事。",
				"写代码，也写生活。",
			];
			let phraseIndex = 0;
			let charIndex = 0;
			let isDeleting = false;
			const el = document.getElementById('typewriter');

			function type() {
				const current = phrases[phraseIndex];
				if (isDeleting) {
					el.textContent = current.substring(0, charIndex - 1);
					charIndex--;
				} else {
					el.textContent = current.substring(0, charIndex + 1);
					charIndex++;
				}

				let speed = isDeleting ? 50 : 100;
				if (!isDeleting && charIndex === current.length) {
					speed = 2000;
					isDeleting = true;
				} else if (isDeleting && charIndex === 0) {
					isDeleting = false;
					phraseIndex = (phraseIndex + 1) % phrases.length;
					speed = 500;
				}
				setTimeout(type, speed);
			}
			type();

			// Site uptime
			const startDate = new Date('2026-05-01T00:00:00');
			function updateUptime() {
				const now = new Date();
				const diff = Math.floor((now - startDate) / (1000 * 60 * 60 * 24));
				const el = document.getElementById('site-days');
				if (el) el.textContent = diff;
			}
			updateUptime();

			// Particle effect
			(function() {
				var canvas = document.getElementById('particle-canvas');
				if (!canvas) return;
				var ctx = canvas.getContext('2d');
				var particles = [];
				var maxParticles = 40;
				var connectionDist = 100;

				function resize() {
					var rect = canvas.parentElement.getBoundingClientRect();
					canvas.width = rect.width;
					canvas.height = rect.height;
				}
				resize();
				window.addEventListener('resize', resize);

				function createParticle() {
					return {
						x: Math.random() * canvas.width,
						y: Math.random() * canvas.height,
						vx: (Math.random() - 0.5) * 0.5,
						vy: (Math.random() - 0.5) * 0.5,
						radius: Math.random() * 2 + 1,
					};
				}

				for (var i = 0; i < maxParticles; i++) {
					particles.push(createParticle());
				}

				function draw() {
					ctx.clearRect(0, 0, canvas.width, canvas.height);
					var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
					var color = isDark ? 'rgba(129,140,248,' : 'rgba(99,102,241,';

					for (var i = 0; i < particles.length; i++) {
						var p = particles[i];
						p.x += p.vx;
						p.y += p.vy;

						if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
						if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

						ctx.beginPath();
						ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
						ctx.fillStyle = color + '0.3)';
						ctx.fill();

						for (var j = i + 1; j < particles.length; j++) {
							var p2 = particles[j];
							var dx = p.x - p2.x;
							var dy = p.y - p2.y;
							var dist = Math.sqrt(dx * dx + dy * dy);
							if (dist < connectionDist) {
								ctx.beginPath();
								ctx.moveTo(p.x, p.y);
								ctx.lineTo(p2.x, p2.y);
								ctx.strokeStyle = color + (0.15 * (1 - dist / connectionDist)) + ')';
								ctx.lineWidth = 1;
								ctx.stroke();
							}
						}
					}
					requestAnimationFrame(draw);
				}
				draw();
			})();
		</script>
	</body>
</html>
