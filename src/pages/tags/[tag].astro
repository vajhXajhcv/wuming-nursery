---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	function slugify(text: string) {
		return text
			.trim()
			.replace(/\//g, '-')
			.replace(/\s+/g, '-');
	}

	const allPosts = [...(await getCollection('blog')), ...(await getCollection('notes'))];
	const tagMap = new Map<string, typeof allPosts>();

	allPosts.forEach((post) => {
		const tags = post.data.tags || [];
		tags.forEach((tag) => {
			if (!tagMap.has(tag)) tagMap.set(tag, []);
			tagMap.get(tag)!.push(post);
		});
	});

	return Array.from(tagMap.entries()).map(([tag, posts]) => ({
		params: { tag: slugify(tag) },
		props: {
			tag,
			posts: posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag, posts } = Astro.props;
const title = `标签：${tag} - ${SITE_TITLE}`;
const description = `查看「${tag}」相关的内容，共 ${posts.length} 篇。`;
---

<BaseLayout title={title} description={description} >
		<style>
			main {
				width: 800px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
				margin-bottom: 1em;
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.9em;
			}
			.back-link:hover {
				color: var(--accent);
			}
			.page-title {
				font-size: 2em;
				margin-bottom: 0.2em;
			}
			.page-title .tag {
				color: var(--accent);
			}
			.page-desc {
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			.post-list {
				display: flex;
				flex-direction: column;
				gap: 0.8em;
			}
			.post-card {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 1em;
				padding: 1em 1.2em;
				border-radius: 12px;
				background: var(--bg-card);
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: border-color 0.2s, transform 0.2s;
			}
			.post-card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
			}
			.post-info {
				display: flex;
				flex-direction: column;
				gap: 0.3em;
				min-width: 0;
			}
			.post-title {
				font-weight: 600;
				color: rgb(var(--black));
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.post-type {
				padding: 0.1em 0.5em;
				border-radius: 4px;
				background: rgb(var(--gray-light));
				font-size: 0.85em;
			}
			.post-date {
				flex-shrink: 0;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.empty {
				text-align: center;
				color: rgb(var(--gray));
				padding: 4em 0;
			}
			@media (max-width: 720px) {
				.post-card {
					flex-direction: column;
					align-items: flex-start;
					gap: 0.5em;
				}
				.post-title {
					white-space: normal;
				}
			}
		</style>
	<main>
			<a href="/tags" class="back-link">← 全部标签</a>
			<h1 class="page-title">标签：<span class="tag">{tag}</span></h1>
			<p class="page-desc">共 {posts.length} 篇相关内容</p>

			{posts.length === 0 && (
				<div class="empty">🌱 这个标签下还没有内容。</div>
			)}

			<div class="post-list">
				{posts.map((post) => (
					<a href={`/${post.collection}/${post.id}/`} class="post-card">
						<div class="post-info">
							<span class="post-title">{post.data.title}</span>
							<span class="post-meta">
								<span class="post-type">{post.collection === 'blog' ? '文章' : '笔记'}</span>
								<span>{post.data.description}</span>
							</span>
						</div>
						<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
					</a>
				))}
			</div>
	</main>
</BaseLayout>
