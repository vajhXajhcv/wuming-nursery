---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const notes = (await getCollection('notes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`笔记 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} >
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.page-title {
				font-size: 2em;
				margin-bottom: 0.2em;
				text-align: center;
			}
			.page-desc {
				text-align: center;
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.search-box {
				max-width: 400px;
				margin: 0 auto 2em;
				position: relative;
			}
			.search-box input {
				width: 100%;
				padding: 0.7em 1em 0.7em 2.5em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				font-size: 1em;
				background: var(--bg-card, #fff);
				color: rgb(var(--gray-dark));
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			.search-box input:focus {
				outline: none;
				border-color: var(--accent);
				box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
			}
			.search-box svg {
				position: absolute;
				left: 1em;
				top: 50%;
				transform: translateY(-50%);
				color: rgb(var(--gray));
				pointer-events: none;
			}
			.no-results {
				text-align: center;
				color: rgb(var(--gray));
				padding: 3em 0;
				display: none;
			}
			.no-results.visible {
				display: block;
			}
			.note-list {
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			.note-item {
				background: var(--bg-card, #fff);
				border-radius: 12px;
				padding: 1.2em 1.5em;
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s, box-shadow 0.2s;
				display: flex;
				align-items: flex-start;
				gap: 1em;
			}
			.note-item:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.note-icon {
				font-size: 1.5em;
				line-height: 1;
				margin-top: 0.1em;
				flex-shrink: 0;
			}
			.note-content {
				flex: 1;
			}
			.note-content h3 {
				margin: 0 0 0.3em;
				font-size: 1.1em;
				color: rgb(var(--black));
			}
			.note-content p {
				margin: 0 0 0.5em;
				font-size: 0.9em;
				color: rgb(var(--gray));
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.note-meta {
				display: flex;
				gap: 0.8em;
				font-size: 0.8em;
				color: rgb(var(--gray));
				align-items: center;
				flex-wrap: wrap;
			}
			.note-meta .tag {
				font-size: 0.75em;
				padding: 0.15em 0.5em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}
			.empty {
				text-align: center;
				color: rgb(var(--gray));
				padding: 4em 0;
			}
		</style>
	<main>
			<h1 class="page-title">笔记</h1>
			<p class="page-desc">技术片段、工具用法和随手记录</p>
			<div class="search-box">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
				<input type="text" id="search-input" placeholder="搜索笔记..." />
			</div>
			<div class="no-results" id="no-results">没有找到匹配的笔记</div>
			<div class="note-list" id="note-list">
				{notes.length === 0 && (
					<div class="empty">🌱 苗圃还在整理，笔记即将发芽...</div>
				)}
				{notes.map((note) => (
					<a href={`/notes/${note.id}/`} class="note-item" data-search={`${note.data.title} ${note.data.description} ${note.data.tags?.join(" ") || ""}`}>
						<span class="note-icon">📌</span>
						<div class="note-content">
							<h3>{note.data.title}</h3>
							<p>{note.data.description}</p>
							<div class="note-meta">
								<FormattedDate date={note.data.pubDate} />
								{note.data.tags && note.data.tags.length > 0 && (
									note.data.tags.map((tag) => <span class="tag">{tag}</span>)
								)}
							</div>
						</div>
					</a>
				))}
			</div>
		</main>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', function() {
				var input = document.getElementById('search-input');
				var list = document.getElementById('note-list');
				var noResults = document.getElementById('no-results');
				if (!input || !list) return;
				var items = list.querySelectorAll('.note-item');
				input.addEventListener('input', function() {
					var q = input.value.trim().toLowerCase();
					var visible = 0;
					items.forEach(function(item) {
						var text = (item.dataset.search || '').toLowerCase();
						if (!q || text.indexOf(q) !== -1) {
							item.style.display = '';
							visible++;
						} else {
							item.style.display = 'none';
						}
					});
					noResults.classList.toggle('visible', visible === 0);
				});
			});
		</script>
</BaseLayout>
