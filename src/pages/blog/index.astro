---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`写作 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.page-title {
				font-size: 2em;
				margin-bottom: 0.2em;
				text-align: center;
			}
			.page-desc {
				text-align: center;
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			.post-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}
			.post-card {
				background: var(--bg-card, #fff);
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 2px 8px rgba(var(--gray), 10%);
				transition: transform 0.25s ease, box-shadow 0.25s ease;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
			}
			.post-card:hover {
				transform: translateY(-5px);
				box-shadow: var(--box-shadow);
			}
			.post-card .thumb {
				width: 100%;
				height: 180px;
				object-fit: cover;
				background: rgb(var(--gray-light));
			}
			.post-card .thumb-placeholder {
				width: 100%;
				height: 180px;
				background: linear-gradient(135deg, rgb(var(--gray-light)) 0%, #e0e4ea 100%);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 3em;
			}
			.post-card .content {
				padding: 1.2em;
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			.post-card h3 {
				margin: 0 0 0.4em;
				font-size: 1.15em;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.post-card p.desc {
				margin: 0 0 0.8em;
				font-size: 0.9em;
				color: rgb(var(--gray));
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
				flex: 1;
			}
			.post-card .meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-top: auto;
			}
			.post-card .tag {
				font-size: 0.75em;
				padding: 0.2em 0.6em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 720px) {
				.post-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">写作</h1>
			<p class="page-desc">记录踩坑过程、游戏感想和生活碎片</p>
			<div class="post-grid">
				{
					posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage ? (
								<Image width={400} height={180} src={post.data.heroImage} alt="" class="thumb" />
							) : (
								<div class="thumb-placeholder">📝</div>
							)}
							<div class="content">
								<h3>{post.data.title}</h3>
								<p class="desc">{post.data.description}</p>
								<div class="meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.tags && post.data.tags.length > 0 ? (
										<span class="tag">{post.data.tags[0]}</span>
									) : (
										<span class="tag">文章</span>
									)}
								</div>
							</div>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
