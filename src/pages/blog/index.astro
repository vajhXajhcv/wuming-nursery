---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`写作 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} >
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.page-title {
				font-size: 2em;
				margin-bottom: 0.2em;
				text-align: center;
			}
			.page-desc {
				text-align: center;
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.search-box {
				max-width: 400px;
				margin: 0 auto 2em;
				position: relative;
			}
			.search-box input {
				width: 100%;
				padding: 0.7em 1em 0.7em 2.5em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				font-size: 1em;
				background: var(--bg-card, #fff);
				color: rgb(var(--gray-dark));
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			.search-box input:focus {
				outline: none;
				border-color: var(--accent);
				box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
			}
			.search-box svg {
				position: absolute;
				left: 1em;
				top: 50%;
				transform: translateY(-50%);
				color: rgb(var(--gray));
				pointer-events: none;
			}
			.no-results {
				text-align: center;
				color: rgb(var(--gray));
				padding: 3em 0;
				display: none;
			}
			.no-results.visible {
				display: block;
			}
			.post-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}
			.post-card {
				background: var(--bg-card, #fff);
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 2px 8px rgba(var(--gray), 10%);
				transition: transform 0.25s ease, box-shadow 0.25s ease;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
			}
			.post-card:hover {
				transform: translateY(-5px);
				box-shadow: var(--box-shadow);
			}
			.post-card .thumb {
				width: 100%;
				height: 180px;
				object-fit: cover;
				background: rgb(var(--gray-light));
			}
			.post-card .thumb-placeholder {
				width: 100%;
				height: 180px;
				background: linear-gradient(135deg, rgb(var(--gray-light)) 0%, #e0e4ea 100%);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 3em;
			}
			.post-card .content {
				padding: 1.2em;
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			.post-card h3 {
				margin: 0 0 0.4em;
				font-size: 1.15em;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.post-card p.desc {
				margin: 0 0 0.8em;
				font-size: 0.9em;
				color: rgb(var(--gray));
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
				flex: 1;
			}
			.post-card .meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-top: auto;
			}
			.post-card .tag {
				font-size: 0.75em;
				padding: 0.2em 0.6em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 720px) {
				.post-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	<main>
			<h1 class="page-title">写作</h1>
			<p class="page-desc">独立开发、AI 工具、一人公司与创作者生意的实践记录</p>
			<div class="search-box">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
				<input type="text" id="search-input" placeholder="搜索文章..." />
			</div>
			<div class="no-results" id="no-results">没有找到匹配的文章</div>
			<div class="post-grid" id="post-grid">
				{
					posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card" data-search={`${post.data.title} ${post.data.description} ${post.data.tags?.join(' ') || ''}`}>
							{post.data.heroImage ? (
								<Image width={400} height={180} src={post.data.heroImage} alt="" class="thumb" />
							) : (
								<div class="thumb-placeholder">📝</div>
							)}
							<div class="content">
								<h3>{post.data.title}</h3>
								<p class="desc">{post.data.description}</p>
								<div class="meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.tags && post.data.tags.length > 0 ? (
										<span class="tag">{post.data.tags[0]}</span>
									) : (
										<span class="tag">文章</span>
									)}
								</div>
							</div>
						</a>
					))
				}
			</div>
		</main>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', function() {
				var input = document.getElementById('search-input');
				var grid = document.getElementById('post-grid');
				var noResults = document.getElementById('no-results');
				if (!input || !grid) return;
				var cards = grid.querySelectorAll('.post-card');
				input.addEventListener('input', function() {
					var q = input.value.trim().toLowerCase();
					var visible = 0;
					cards.forEach(function(card) {
						var text = (card.dataset.search || '').toLowerCase();
						if (!q || text.indexOf(q) !== -1) {
							card.style.display = '';
							visible++;
						} else {
							card.style.display = 'none';
						}
					});
					noResults.classList.toggle('visible', visible === 0);
				});
			});
		</script>
</BaseLayout>
