---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pages = [
	{ title: '首页', url: '/' },
	{ title: '写作', url: '/blog' },
	{ title: '关于', url: '/about' },
	{ title: '项目', url: '/projects/docx-formatter-cn' },
	{ title: '使用文档', url: '/projects/docx-formatter-docs' },
];
---

<BaseLayout title={`网站地图 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} >
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.page-title {
				font-size: 2em;
				margin-bottom: 0.2em;
				text-align: center;
			}
			.page-desc {
				text-align: center;
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			.section {
				margin: 2em 0;
			}
			.section h2 {
				font-size: 1.3em;
				padding-bottom: 0.3em;
				border-bottom: 2px solid rgb(var(--gray-light));
				margin-bottom: 0.8em;
			}
			.link-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.link-list li {
				margin: 0.6em 0;
			}
			.link-list a {
				color: rgb(var(--gray-dark));
				text-decoration: none;
				padding: 0.5em 0.8em;
				border-radius: 8px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				transition: background 0.2s, color 0.2s;
			}
			.link-list a:hover {
				background: rgb(var(--gray-light));
				color: var(--accent);
			}
			.link-list .meta {
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.tag {
				font-size: 0.75em;
				padding: 0.15em 0.5em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				margin-left: 0.5em;
			}
		</style>
	<main>
			<h1 class="page-title">网站地图</h1>
			<p class="page-desc">快速导航到网站的每一个角落</p>

			<section class="section">
				<h2>📄 页面</h2>
				<ul class="link-list">
					{pages.map((page) => (
						<li>
							<a href={page.url}>
								<span>{page.title}</span>
								<span class="meta">{page.url}</span>
							</a>
						</li>
					))}
				</ul>
			</section>

			<section class="section">
				<h2>📝 文章</h2>
				<ul class="link-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span>
									{post.data.title}
									{post.data.tags?.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</span>
								<span class="meta">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						</li>
					))}
				</ul>
			</section>
	</main>
</BaseLayout>
