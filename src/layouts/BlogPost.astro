---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	readingTime?: number;
	wordCount?: number;
	relatedPosts?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, updatedDate, heroImage, tags, prevPost, nextPost, readingTime, wordCount, relatedPosts } = Astro.props;
---

<BaseLayout title={title} description={description} article={true} pubDate={pubDate} updatedDate={updatedDate} tags={tags}>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.prose h1,
			.prose h2,
			.prose h3,
			.prose h4 {
				color: rgb(var(--black));
			}
			.prose hr {
				border-color: rgb(var(--gray-light));
			}
			.prose blockquote {
				border-left: 4px solid var(--accent);
				background: rgba(var(--gray-light), 0.3);
				padding: 0.5em 1em;
				border-radius: 0 8px 8px 0;
				margin: 1em 0;
			}
			.prose code {
				background: var(--bg-code);
				padding: 0.2em 0.4em;
				border-radius: 4px;
				font-size: 0.9em;
			}
			.prose pre {
				background: var(--bg-code);
				padding: 1em;
				border-radius: 8px;
				overflow-x: auto;
			}
			.prose pre code {
				background: none;
				padding: 0;
			}
			.prose table {
				border-collapse: collapse;
				width: 100%;
				margin: 1em 0;
			}
			.prose th,
			.prose td {
				border: 1px solid rgb(var(--gray-light));
				padding: 0.5em;
				text-align: left;
			}
			.prose th {
				background: rgba(var(--gray-light), 0.5);
				font-weight: 700;
			}
			.prose img {
				max-width: 100%;
				border-radius: 8px;
			}
			.prose a {
				color: var(--accent);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.meta-bar {
				display: flex;
				gap: 1em;
				justify-content: center;
				align-items: center;
				flex-wrap: wrap;
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin-bottom: 0.5em;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				gap: 0.5em;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.8em;
			}
			.tag {
				font-size: 0.8em;
				padding: 0.2em 0.7em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				text-decoration: none;
				transition: background 0.2s, color 0.2s;
			}
			.tag:hover {
				background: var(--accent);
				color: white;
			}
			/* Prev/Next navigation */
			.post-nav {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto 0;
				padding: 1em;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1em;
			}
			.nav-card {
				padding: 1em;
				border-radius: 12px;
				background: var(--bg-card, #fff);
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s, box-shadow 0.2s;
			}
			.nav-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.nav-card.next {
				text-align: right;
			}
			.nav-label {
				font-size: 0.75em;
				color: rgb(var(--gray));
				margin-bottom: 0.3em;
			}
			.nav-title {
				font-size: 1em;
				color: rgb(var(--black));
				font-weight: 600;
			}
			.comments {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 3em auto 0;
				padding: 1em;
			}
			.comments-title {
				font-size: 1.3em;
				margin-bottom: 0.8em;
				padding-bottom: 0.3em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			/* Copy button for code blocks */
			.code-block-wrapper {
				position: relative;
			}
			.copy-btn {
				position: absolute;
				top: 0.5em;
				right: 0.5em;
				padding: 0.3em 0.7em;
				border-radius: 6px;
				background: rgba(255,255,255,0.1);
				color: rgb(var(--gray));
				border: 1px solid rgba(255,255,255,0.15);
				cursor: pointer;
				font-size: 0.8em;
				opacity: 0;
				transition: opacity 0.2s, background 0.2s;
			}
			.code-block-wrapper:hover .copy-btn {
				opacity: 1;
			}
			.copy-btn:hover {
				background: var(--accent);
				color: white;
			}
			.copy-btn.copied {
				background: #22c55e;
				color: white;
				opacity: 1;
			}
			/* Heading anchor links */
			.prose h2,
			.prose h3 {
				position: relative;
			}
			.heading-anchor {
				display: inline-block;
				margin-left: 0.3em;
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.8em;
				opacity: 0;
				transition: opacity 0.2s;
				cursor: pointer;
			}
			.prose h2:hover .heading-anchor,
			.prose h3:hover .heading-anchor {
				opacity: 1;
			}
			/* TOC Sidebar */
			.toc-wrapper {
				display: none;
			}
			@media (min-width: 1200px) {
				.toc-wrapper {
					display: block;
					position: fixed;
					top: 100px;
					right: calc((100% - 720px) / 2 - 220px);
					width: 200px;
					max-height: calc(100vh - 140px);
					overflow-y: auto;
				}
				.toc-title {
					font-size: 0.85em;
					font-weight: 700;
					color: rgb(var(--black));
					margin-bottom: 0.5em;
					padding-bottom: 0.3em;
					border-bottom: 1px solid rgb(var(--gray-light));
				}
				.toc-list {
					list-style: none;
					padding: 0;
					margin: 0;
				}
				.toc-list li {
					margin: 0.3em 0;
				}
				.toc-list a {
					display: block;
					padding: 0.25em 0.5em;
					border-radius: 4px;
					color: rgb(var(--gray));
					text-decoration: none;
					font-size: 0.8em;
					line-height: 1.4;
					transition: background 0.15s, color 0.15s;
				}
				.toc-list a:hover,
				.toc-list a.active {
					background: rgb(var(--gray-light));
					color: var(--accent);
				}
				.toc-list li.h3 {
					padding-left: 1em;
				}
			}
			/* Related posts */
				/* Mobile TOC */
				.toc-mobile {
					display: none;
				}
				@media (max-width: 1199px) {
					.toc-mobile {
						display: block;
						margin: 1em 0;
					}
					.toc-mobile-toggle {
						display: flex;
						align-items: center;
						justify-content: space-between;
						width: 100%;
						padding: 0.6em 1em;
						background: var(--bg-card, #fff);
						border: 1px solid rgb(var(--gray-light));
						border-radius: 8px;
						font-size: 0.95em;
						color: rgb(var(--black));
						cursor: pointer;
						transition: background 0.2s;
					}
					.toc-mobile-toggle:hover {
						background: rgb(var(--gray-light));
					}
					.toc-mobile-toggle .toc-arrow {
						font-size: 0.75em;
						transition: transform 0.2s;
					}
					.toc-mobile.open .toc-arrow {
						transform: rotate(180deg);
					}
					.toc-mobile-content {
						max-height: 0;
						overflow: hidden;
						transition: max-height 0.3s ease;
					}
					.toc-mobile.open .toc-mobile-content {
						max-height: 500px;
					}
					.toc-mobile-list {
						list-style: none;
						padding: 0.5em 0 0;
						margin: 0;
					}
					.toc-mobile-list li {
						margin: 0.3em 0;
					}
					.toc-mobile-list a {
						display: block;
						padding: 0.4em 0.8em;
						border-radius: 4px;
						color: rgb(var(--gray));
						text-decoration: none;
						font-size: 0.9em;
						line-height: 1.4;
						transition: background 0.15s, color 0.15s;
					}
					.toc-mobile-list a:hover,
					.toc-mobile-list a.active {
						background: rgb(var(--gray-light));
						color: var(--accent);
					}
					.toc-mobile-list li.h3 {
						padding-left: 1em;
					}
				}
			.related-posts {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto 0;
				padding: 1em;
			}
			.related-posts h3 {
				font-size: 1.2em;
				margin-bottom: 0.8em;
				padding-bottom: 0.3em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1em;
			}
			.related-card {
				padding: 1em;
				border-radius: 10px;
				background: var(--bg-card, #fff);
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s, box-shadow 0.2s;
			}
			.related-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.related-card .r-title {
				font-weight: 600;
				color: rgb(var(--black));
				margin-bottom: 0.3em;
			}
			.related-card .r-desc {
				font-size: 0.85em;
				color: rgb(var(--gray));
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			/* Progress bar */
			.read-progress {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				background: var(--accent);
				z-index: 1000;
				width: 0%;
				transition: width 0.1s linear;
			}
			/* Share buttons */
			.share-bar {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto 0;
				padding: 1em;
				display: flex;
				align-items: center;
				gap: 0.5em;
				flex-wrap: wrap;
			}
			.share-label {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-right: 0.5em;
			}
			.share-btn {
				padding: 0.4em 0.9em;
				border-radius: 8px;
				background: var(--bg-card, #fff);
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				font-size: 0.85em;
				cursor: pointer;
				transition: background 0.2s, border-color 0.2s, transform 0.2s;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
			}
			.share-btn:hover {
				transform: translateY(-2px);
				border-color: var(--accent);
				color: var(--accent);
			}
			/* Lightbox */
			.lightbox-overlay {
				position: fixed;
				top: 0; left: 0;
				width: 100%; height: 100%;
				background: rgba(0,0,0,0.9);
				z-index: 2000;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: zoom-out;
				opacity: 0;
				transition: opacity 0.2s;
				pointer-events: none;
			}
			.lightbox-overlay.active {
				opacity: 1;
				pointer-events: auto;
			}
			.lightbox-overlay img {
				max-width: 90vw;
				max-height: 90vh;
				object-fit: contain;
				border-radius: 8px;
				cursor: default;
			}
			.lightbox-close {
				position: absolute;
				top: 1em; right: 1em;
				color: white;
				font-size: 2em;
				cursor: pointer;
				line-height: 1;
			}
			/* Code fold */
			.code-fold-wrapper.collapsed pre {
				max-height: 300px;
				overflow: hidden;
			}
			.code-fold-wrapper.collapsed::after {
				content: '';
				position: absolute;
				bottom: 0; left: 0; right: 0;
				height: 60px;
				background: linear-gradient(transparent, var(--bg-code));
				pointer-events: none;
			}
			.code-fold-btn {
				display: block;
				width: 100%;
				padding: 0.5em;
				background: var(--bg-code);
				border: 1px solid rgb(var(--gray-light));
				border-top: none;
				border-radius: 0 0 8px 8px;
				color: rgb(var(--gray));
				font-size: 0.8em;
				cursor: pointer;
				text-align: center;
			}
			.code-fold-btn:hover {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.post-nav {
					grid-template-columns: 1fr;
				}
				.nav-card.next {
					text-align: left;
				}
			}
		</style>
		<div class="read-progress" id="read-progress"></div>
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="meta-bar">
							<span><FormattedDate date={pubDate} /></span>
							{readingTime && <span>⏱️ 约 {readingTime} 分钟</span>}
							{wordCount && <span>📝 {wordCount.toLocaleString()} 字</span>}
							{
								updatedDate && (
									<span class="last-updated-on">
										更新于 <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</div>
						<h1>{title}</h1>
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						)}
						<hr />
					</div>

						<!-- Mobile TOC -->
						<div class="toc-mobile" id="toc-mobile">
							<button class="toc-mobile-toggle" id="toc-mobile-toggle">
								📑 目录 <span class="toc-arrow">▼</span>
							</button>
							<div class="toc-mobile-content" id="toc-mobile-content">
								<ul class="toc-mobile-list" id="toc-mobile-list"></ul>
							</div>
						</div>
					<slot />
				</div>
			</article>
			<!-- Share Bar -->
			<div class="share-bar">
				<span class="share-label">分享：</span>
				<button class="share-btn" id="share-weibo" title="分享到微博">📢 微博</button>
				<button class="share-btn" id="share-weixin" title="复制链接">🔗 复制链接</button>
				<button class="share-btn" id="share-x" title="分享到 X">𝕏 X</button>
			</div>
		</main>

		<!-- Prev/Next Navigation -->
		{(prevPost || nextPost) && (
			<nav class="post-nav">
				{prevPost ? (
					<a href={`/blog/${prevPost.id}/`} class="nav-card">
						<div class="nav-label">← 上一篇</div>
						<div class="nav-title">{prevPost.data.title}</div>
					</a>
				) : <div />}
				{nextPost ? (
					<a href={`/blog/${nextPost.id}/`} class="nav-card next">
						<div class="nav-label">下一篇 →</div>
						<div class="nav-title">{nextPost.data.title}</div>
					</a>
				) : <div />}
			</nav>
		)}

		{relatedPosts && relatedPosts.length > 0 && (
			<div class="related-posts">
				<h3>📎 相关文章</h3>
				<div class="related-grid">
					{relatedPosts.map((rp) => (
						<a href={`/blog/${rp.id}/`} class="related-card">
							<div class="r-title">{rp.data.title}</div>
							<div class="r-desc">{rp.data.description}</div>
						</a>
					))}
				</div>
			</div>
		)}

		<!-- TOC Sidebar -->
		<div class="toc-wrapper" id="toc-wrapper">
			<div class="toc-title">目录</div>
			<ul class="toc-list" id="toc-list"></ul>
		</div>

		<!-- Utterances Comments -->
		<div class="comments">
			<h3 class="comments-title">💬 留言</h3>
			<script src="https://giscus.app/client.js"
				data-repo="vajhxajhcv/wuming-nursery"
					data-repo-id="R_kgDOOeC-1A"
				data-category="Announcements"
					data-category-id="DIC_kwDOOeC-1M4CpZbD"
					data-mapping="pathname"
				data-strict="0"
				data-reactions-enabled="1"
					data-emit-metadata="0"
					data-input-position="bottom"
					data-theme="preferred_color_scheme"
					data-lang="zh-CN"
				crossorigin="anonymous"
				async>
			</script>
		</div>



		<script is:inline>
			// Copy button for code blocks
			document.addEventListener('DOMContentLoaded', function() {
				document.querySelectorAll('pre').forEach(function(pre) {
					var wrapper = document.createElement('div');
					wrapper.className = 'code-block-wrapper';
					pre.parentNode.insertBefore(wrapper, pre);
					wrapper.appendChild(pre);

					var btn = document.createElement('button');
					btn.className = 'copy-btn';
					btn.textContent = '复制';
					btn.setAttribute('aria-label', '复制代码');
					wrapper.appendChild(btn);

					btn.addEventListener('click', function() {
						var code = pre.querySelector('code');
						var text = code ? code.textContent : pre.textContent;
						navigator.clipboard.writeText(text).then(function() {
							btn.textContent = '已复制';
							btn.classList.add('copied');
							setTimeout(function() {
								btn.textContent = '复制';
								btn.classList.remove('copied');
							}, 2000);
						});
					});
				});

				// Generate TOC
				var prose = document.querySelector('.prose');
				var tocList = document.getElementById('toc-list');
						var tocMobileList = document.getElementById('toc-mobile-list');
				if (prose && tocList) {
					var headings = prose.querySelectorAll('h2, h3');
					headings.forEach(function(h, i) {
						var id = 'heading-' + i;
						h.id = id;
						var li = document.createElement('li');
						li.className = h.tagName.toLowerCase() === 'h3' ? 'h3' : '';
						var a = document.createElement('a');
						a.href = '#' + id;
						a.textContent = h.textContent;
						a.addEventListener('click', function(e) {
							e.preventDefault();
							h.scrollIntoView({ behavior: 'smooth', block: 'start' });
							history.pushState(null, null, '#' + id);
						});
						li.appendChild(a);
						tocList.appendChild(li);
								if (tocMobileList) {
									var mLi = li.cloneNode(true);
									mLi.querySelector('a').addEventListener('click', function(e) {
										e.preventDefault();
										h.scrollIntoView({ behavior: 'smooth', block: 'start' });
										history.pushState(null, null, '#' + id);
										document.getElementById('toc-mobile').classList.remove('open');
									});
									tocMobileList.appendChild(mLi);
								}
					});

					// Highlight active TOC item on scroll
					var tocLinks = tocList.querySelectorAll('a');
							var tocMobileLinks = tocMobileList ? tocMobileList.querySelectorAll('a') : [];
					function onScroll() {
						var scrollPos = window.scrollY + 120;
						var activeId = '';
						headings.forEach(function(h) {
							var tocMobileToggle = document.getElementById('toc-mobile-toggle');
							var tocMobile = document.getElementById('toc-mobile');
							if (tocMobileToggle && tocMobile) {
								tocMobileToggle.addEventListener('click', function() {
									tocMobile.classList.toggle('open');
								});
							}

							if (h.offsetTop <= scrollPos) {
								activeId = h.id;
							}
						});
						tocLinks.forEach(function(a) {
							a.classList.toggle('active', a.getAttribute('href') === '#' + activeId);
						});
								Array.from(tocMobileLinks).forEach(function(a) {
									a.classList.toggle('active', a.getAttribute('href') === '#' + activeId);
								});
					}
					window.addEventListener('scroll', onScroll, { passive: true });
					onScroll();

					// Heading anchor links
					headings.forEach(function(h) {
						var anchor = document.createElement('a');
						anchor.href = '#' + h.id;
						anchor.className = 'heading-anchor';
						anchor.innerHTML = '¶';
						anchor.title = '复制链接';
						anchor.addEventListener('click', function(e) {
							e.preventDefault();
							var url = window.location.origin + window.location.pathname + '#' + h.id;
							navigator.clipboard.writeText(url).then(function() {
								anchor.style.color = '#22c55e';
								setTimeout(function() { anchor.style.color = ''; }, 1500);
							});
						});
						h.appendChild(anchor);
					});
				}

				// Reading progress bar
				var progressBar = document.getElementById('read-progress');
				if (progressBar) {
					function updateProgress() {
						var scrollTop = window.scrollY;
						var docHeight = document.documentElement.scrollHeight - window.innerHeight;
						var pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
						progressBar.style.width = pct + '%';
					}
					window.addEventListener('scroll', updateProgress, { passive: true });
					updateProgress();
				}

				// Share buttons
				var shareUrl = encodeURIComponent(window.location.href);
				var shareTitle = encodeURIComponent(document.title);
				var weiboBtn = document.getElementById('share-weibo');
				if (weiboBtn) {
					weiboBtn.addEventListener('click', function() {
						window.open('https://service.weibo.com/share/share.php?url=' + shareUrl + '&title=' + shareTitle, '_blank', 'width=600,height=400');
					});
				}
				var xBtn = document.getElementById('share-x');
				if (xBtn) {
					xBtn.addEventListener('click', function() {
						window.open('https://twitter.com/intent/tweet?url=' + shareUrl + '&text=' + shareTitle, '_blank', 'width=600,height=400');
					});
				}
				var copyBtn = document.getElementById('share-weixin');
				if (copyBtn) {
					copyBtn.addEventListener('click', function() {
						navigator.clipboard.writeText(window.location.href).then(function() {
							var orig = copyBtn.textContent;
							copyBtn.textContent = '✅ 已复制';
							setTimeout(function() { copyBtn.textContent = orig; }, 2000);
						});
					});
				}

				// External links: open in new tab + add icon
				document.querySelectorAll('.prose a').forEach(function(a) {
					var href = a.getAttribute('href') || '';
					if (href.startsWith('http') && !href.includes(window.location.hostname)) {
						a.setAttribute('target', '_blank');
						a.setAttribute('rel', 'noopener noreferrer');
						a.classList.add('external-link');
					}
				});

			// Image lightbox
			document.querySelectorAll('.prose img').forEach(function(img) {
				img.style.cursor = 'zoom-in';
				img.addEventListener('click', function(e) {
					e.preventDefault();
					var overlay = document.createElement('div');
					overlay.className = 'lightbox-overlay';
					var bigImg = document.createElement('img');
					bigImg.src = img.src;
					bigImg.alt = img.alt || '';
					var closeBtn = document.createElement('span');
					closeBtn.className = 'lightbox-close';
					closeBtn.innerHTML = '&times;';
					overlay.appendChild(bigImg);
					overlay.appendChild(closeBtn);
					document.body.appendChild(overlay);
					requestAnimationFrame(function() { overlay.classList.add('active'); });
					function close() {
						overlay.classList.remove('active');
						setTimeout(function() { overlay.remove(); }, 200);
					}
					overlay.addEventListener('click', function(ev) {
						if (ev.target === overlay || ev.target === closeBtn) close();
					});
					document.addEventListener('keydown', function keyHandler(ev) {
						if (ev.key === 'Escape') { close(); document.removeEventListener('keydown', keyHandler); }
					});
				});
			});

			// Code block fold (for blocks > 15 lines)
			document.querySelectorAll('pre').forEach(function(pre) {
				var lines = pre.textContent.split('\n').length;
				if (lines > 15) {
					var wrapper = pre.parentNode;
					if (wrapper.classList.contains('code-block-wrapper')) {
						wrapper.classList.add('code-fold-wrapper', 'collapsed');
						var btn = document.createElement('button');
						btn.className = 'code-fold-btn';
						btn.textContent = '展开 ' + lines + ' 行代码';
						btn.addEventListener('click', function() {
							var isCollapsed = wrapper.classList.contains('collapsed');
							wrapper.classList.toggle('collapsed');
							btn.textContent = isCollapsed ? '收起代码' : '展开 ' + lines + ' 行代码';
						});
						wrapper.appendChild(btn);
					}
				}
			});
		</script>
</BaseLayout>
