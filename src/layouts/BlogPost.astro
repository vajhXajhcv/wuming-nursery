---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	readingTime?: number;
};

const { title, description, pubDate, updatedDate, heroImage, tags, prevPost, nextPost, readingTime } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.prose h1,
			.prose h2,
			.prose h3,
			.prose h4 {
				color: rgb(var(--black));
			}
			.prose hr {
				border-color: rgb(var(--gray-light));
			}
			.prose blockquote {
				border-left: 4px solid var(--accent);
				background: rgba(var(--gray-light), 0.3);
				padding: 0.5em 1em;
				border-radius: 0 8px 8px 0;
				margin: 1em 0;
			}
			.prose code {
				background: var(--bg-code);
				padding: 0.2em 0.4em;
				border-radius: 4px;
				font-size: 0.9em;
			}
			.prose pre {
				background: var(--bg-code);
				padding: 1em;
				border-radius: 8px;
				overflow-x: auto;
			}
			.prose pre code {
				background: none;
				padding: 0;
			}
			.prose table {
				border-collapse: collapse;
				width: 100%;
				margin: 1em 0;
			}
			.prose th,
			.prose td {
				border: 1px solid rgb(var(--gray-light));
				padding: 0.5em;
				text-align: left;
			}
			.prose th {
				background: rgba(var(--gray-light), 0.5);
				font-weight: 700;
			}
			.prose img {
				max-width: 100%;
				border-radius: 8px;
			}
			.prose a {
				color: var(--accent);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.meta-bar {
				display: flex;
				gap: 1em;
				justify-content: center;
				align-items: center;
				flex-wrap: wrap;
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin-bottom: 0.5em;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				gap: 0.5em;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.8em;
			}
			.tag {
				font-size: 0.8em;
				padding: 0.2em 0.7em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				text-decoration: none;
				transition: background 0.2s, color 0.2s;
			}
			.tag:hover {
				background: var(--accent);
				color: white;
			}
			/* Prev/Next navigation */
			.post-nav {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto 0;
				padding: 1em;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1em;
			}
			.nav-card {
				padding: 1em;
				border-radius: 12px;
				background: var(--bg-card, #fff);
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s, box-shadow 0.2s;
			}
			.nav-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.nav-card.next {
				text-align: right;
			}
			.nav-label {
				font-size: 0.75em;
				color: rgb(var(--gray));
				margin-bottom: 0.3em;
			}
			.nav-title {
				font-size: 1em;
				color: rgb(var(--black));
				font-weight: 600;
			}
			.comments {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 3em auto 0;
				padding: 1em;
			}
			.comments-title {
				font-size: 1.3em;
				margin-bottom: 0.8em;
				padding-bottom: 0.3em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			@media (max-width: 720px) {
				.post-nav {
					grid-template-columns: 1fr;
				}
				.nav-card.next {
					text-align: left;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="meta-bar">
							<span><FormattedDate date={pubDate} /></span>
							{readingTime && <span>⏱️ 约 {readingTime} 分钟</span>}
							{
								updatedDate && (
									<span class="last-updated-on">
										更新于 <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</div>
						<h1>{title}</h1>
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						)}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>

		<!-- Prev/Next Navigation -->
		{(prevPost || nextPost) && (
			<nav class="post-nav">
				{prevPost ? (
					<a href={`/blog/${prevPost.id}/`} class="nav-card">
						<div class="nav-label">← 上一篇</div>
						<div class="nav-title">{prevPost.data.title}</div>
					</a>
				) : <div />}
				{nextPost ? (
					<a href={`/blog/${nextPost.id}/`} class="nav-card next">
						<div class="nav-label">下一篇 →</div>
						<div class="nav-title">{nextPost.data.title}</div>
					</a>
				) : <div />}
			</nav>
		)}

		<!-- Utterances Comments -->
		<div class="comments">
			<h3 class="comments-title">💬 留言</h3>
			<script src="https://utteranc.es/client.js"
				repo="vajhxajhcv/wuming-nursery"
				issue-term="pathname"
				label="comment"
				theme="preferred-color-scheme"
				crossorigin="anonymous"
				async>
			</script>
		</div>

		<Footer />
	</body>
</html>
